<Window x:Class="HazardGuessr.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="確認"
        Width="450"
        Height="250"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        AllowsTransparency="True">

    <Grid>
      
        <!-- ダイアログボックス -->
        <Border Background="#FF1A1A2E"
                CornerRadius="15"
                BorderBrush="#FF007ACC"
                BorderThickness="3"
                Width="400"
                Height="200"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <Grid Margin="25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- メッセージ -->
                <TextBlock x:Name="MessageText"
                          Text="メッセージがここに表示されます"
                          Foreground="White"
                          FontSize="18"
                          TextWrapping="Wrap"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          TextAlignment="Center"/>

                <!-- ボタン -->
                <StackPanel Grid.Row="1"
                           Orientation="Horizontal"
                           HorizontalAlignment="Center"
                           Margin="0,20,0,0">

                    <!-- はいボタン -->
                    <Button x:Name="YesButton"
                           Content="はい"
                           Width="120"
                           Height="45"
                           Background="#FF007ACC"
                           Foreground="White"
                           FontSize="16"
                           FontWeight="Bold"
                           BorderThickness="0"
                           Margin="0,0,20,0"
                           Click="YesButton_Click"
                           Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Opacity" Value="0.9"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="1"/>
                                        <Setter Property="Background" Value="#FF0099FF"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- いいえボタン -->
                    <Button x:Name="NoButton"
                           Content="いいえ"
                           Width="120"
                           Height="45"
                           Background="#FF2D2D40"
                           Foreground="White"
                           FontSize="16"
                           BorderBrush="#FF007ACC"
                           BorderThickness="2"
                           Click="NoButton_Click"
                           Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Opacity" Value="0.9"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="1"/>
                                        <Setter Property="Background" Value="#FF3D3D50"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>