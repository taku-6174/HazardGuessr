<Window x:Class="HazardGuessr.RankingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        Title="HazardGuessr - ランキング">

    <Grid>
        <!-- 背景グラデーション -->
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="Black"/>
                <GradientStop Color="#FF002158" Offset="1"/>
                <GradientStop Color="#FF000073"/>
                <GradientStop Color="#FF001A6B" Offset="0.9"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- メインコンテンツ -->
        <Grid>
            <!-- タイトル -->
            <TextBlock Text="ランキング"
                      FontSize="48"
                      FontWeight="Bold"
                      Foreground="#FF00A8FF"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Top"
                      Margin="0,50,0,0"/>

            <!-- サブタイトル -->
            <TextBlock x:Name="SubTitleText"
                      Text="最高スコア TOP10"
                      FontSize="20"
                      Foreground="#CCCCCC"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Top"
                      Margin="0,120,0,0"/>

            <!-- ランキング表示エリア -->
            <Border x:Name="RankingContainer"
                   Background="#FF1A1A2E"
                   CornerRadius="15"
                   BorderBrush="#FF007ACC"
                   BorderThickness="3"
                   Width="900"
                   Height="500"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center">

                <!-- ここにコードでランキングを追加 -->
                <ScrollViewer x:Name="RankingScrollViewer"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="RankingStackPanel"/>
                </ScrollViewer>
            </Border>

            <!-- データなしメッセージ -->
            <Border x:Name="NoDataMessage"
                   Background="#FF2D2D40"
                   CornerRadius="10"
                   BorderBrush="#FF007ACC"
                   BorderThickness="2"
                   Padding="40"
                   Width="500"
                   Height="200"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Visibility="Collapsed">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="📊 ランキングデータがありません"
                              FontSize="24"
                              FontWeight="Bold"
                              Foreground="#FF00A8FF"
                              TextWrapping="Wrap"
                              TextAlignment="Center"
                              Margin="0,0,0,20"/>

                    <TextBlock Text="ゲームをプレイしてランキングに登録しましょう！"
                              FontSize="18"
                              Foreground="#CCCCCC"
                              TextWrapping="Wrap"
                              TextAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- 自分の順位表示 -->
            <Border x:Name="MyRankPanel"
                   Background="#FF2D2D40"
                   CornerRadius="10"
                   Padding="15"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   Margin="0,0,0,100"
                   Visibility="Collapsed">
                <TextBlock x:Name="MyRankText"
                          FontSize="18"
                          Foreground="#CCCCCC"/>
            </Border>

            <!-- ボタンエリア -->
            <StackPanel HorizontalAlignment="Center"
                       VerticalAlignment="Bottom"
                       Orientation="Horizontal"
                       Margin="0,0,0,30">

                <Button x:Name="RefreshButton"
                       Content="更新"
                       Width="150"
                       Height="50"
                       Background="#FF2D2D40"
                       Foreground="White"
                       FontSize="16"
                       BorderBrush="#FF007ACC"
                       BorderThickness="2"
                       Margin="0,0,20,0"
                       Cursor="Hand"
                       Click="RefreshButton_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Opacity" Value="0.9"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="1"/>
                                    <Setter Property="Background" Value="#FF3D3D50"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button x:Name="HomeButton"
                       Content="ホームに戻る"
                       Width="180"
                       Height="50"
                       Background="#FF007ACC"
                       Foreground="White"
                       FontSize="18"
                       FontWeight="Bold"
                       BorderThickness="0"
                       Cursor="Hand"
                       Click="HomeButton_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Opacity" Value="0.9"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="1"/>
                                    <Setter Property="Background" Value="#FF0099FF"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

           
        </Grid>
    </Grid>
</Window>