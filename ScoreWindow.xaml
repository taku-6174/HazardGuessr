<Window x:Class="HazardGuessr.ScoreWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" 
        WindowState="Maximized"
        ResizeMode="NoResize"
        Title="HazardGuessr - 最終結果">

    <Grid>
        <!-- 背景グラデーション（他の画面と同じ） -->
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="Black"/>
                <GradientStop Color="#FF002158" Offset="1"/>
                <GradientStop Color="#FF000073"/>
                <GradientStop Color="#FF001A6B" Offset="0.9"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- メインコンテンツ（全画面対応） -->
        <Grid>
            <!-- タイトル部分 -->
            <Grid HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,50,0,0">
                <TextBlock Text="最終結果"
                          FontSize="48"
                          FontWeight="Bold"
                          Foreground="#FF00A8FF"
                          HorizontalAlignment="Center"/>
            </Grid>

            <!-- 中央コンテンツエリア -->
            <Border Background="#FF1A1A2E"
                    CornerRadius="20"
                    BorderBrush="#FF007ACC"
                    BorderThickness="3"
                    Width="700"
                    Height="550"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                <Grid Margin="40">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- スコア表示エリア -->
                    <Border Grid.Row="0"
                           Background="#FF2D2D40"
                           CornerRadius="15"
                           Padding="4">

                        <StackPanel VerticalAlignment="Center">
                            <!-- ラベル -->
                            <TextBlock Text="TOTAL SCORE"
                                      FontSize="28"
                                      Foreground="#CCCCCC"
                                      HorizontalAlignment="Center"
                                      Margin="0,0,0,30"/>

                            <!-- スコア数値 -->
                            <TextBlock x:Name="TotalScoreDisplay"
                                      Text="0 P"
                                      FontSize="96"
                                      FontWeight="Bold"
                                      Foreground="Gold"
                                      HorizontalAlignment="Center"
                                      Margin="0,0,0,40" Height="121"/>

                            <!-- プレイヤー名表示 -->
                            <TextBlock x:Name="PlayerNameText"
                                      Text="プレイヤー: --"
                                      FontSize="22"
                                      Foreground="#888888"
                                      HorizontalAlignment="Center"/>

                            <!-- 最高スコア比較 -->
                            <TextBlock x:Name="HighScoreComparisonText"
                                      Text=""
                                      FontSize="18"
                                      Foreground="#666666"
                                      HorizontalAlignment="Center"
                                      Margin="0,30,0,0"
                                      Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>

                    <!-- メッセージエリア -->
                    <TextBlock x:Name="MessageText"
                              Grid.Row="1"
                              Text="お疲れ様でした！"
                              FontSize="24"
                              Foreground="White"
                              HorizontalAlignment="Center"
                              Margin="0,40,0,30"
                              TextWrapping="Wrap"/>

                    <!-- ボタンエリア -->
                    <StackPanel Grid.Row="2"
                               HorizontalAlignment="Center"
                               Orientation="Horizontal">

                        <!-- ホームに戻るボタン -->
                        <Button x:Name="HomeButton"
                               Content="ホームに戻る"
                               Width="200"
                               Height="60"
                               Background="#FF007ACC"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="Bold"
                               BorderThickness="0"
                               Margin="0,0,25,0"
                               Cursor="Hand"
                               Click="HomeButton_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="12"/>
                                </Style>
                            </Button.Resources>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Opacity" Value="0.9"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="1"/>
                                            <Setter Property="Background" Value="#FF0099FF"/>
                                            <Setter Property="RenderTransform">
                                                <Setter.Value>
                                                    <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        
                    </StackPanel>
                </Grid>
            </Border>

          
            <!-- 右下にバージョン情報など -->
            <TextBlock Text="HazardGuessr v1.0"
                      Foreground="#444444"
                      FontSize="14"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Bottom"
                      Margin="0,0,30,20"/>
        </Grid>
    </Grid>
</Window>