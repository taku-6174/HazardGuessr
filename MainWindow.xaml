<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:av="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="av" x:Class="HazardGuessr.MainWindow"
        WindowStyle="None" 
        WindowState="Maximized"
        Title="HazardGuessr"
        KeyDown="MainWindow_KeyDown" av:DesignHeight="641.088" av:DesignWidth="998.054">

    <Grid>
        <!-- 背景グラデーション（HomeWindowと同じ） -->
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="Black"/>
                <GradientStop Color="#FF002158" Offset="1"/>
                <GradientStop Color="#FF000073"/>
                <GradientStop Color="#FF001A6B" Offset="0.9"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- メインコンテンツ -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <!-- メインエリア -->
                <RowDefinition Height="Auto"/>
                <!-- ボタンエリア -->
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <!-- 左サイドバー -->
                <ColumnDefinition Width="*"/>
                <!-- マップエリア -->
                <ColumnDefinition Width="250"/>
                <!-- 右サイドバー -->
            </Grid.ColumnDefinitions>

            <!-- ========== 左サイドバー：ゲーム情報 ========== -->
            <Border Grid.Row="0" Grid.Column="0" 
                   Background="#1A237E"
                   BorderBrush="#1A237E"
                   BorderThickness="0,0,2,0">

                <StackPanel Margin="20">
                    <!-- タイトル -->
                    <TextBlock Text="Hazard Guessr"
                              FontSize="24"
                              FontWeight="Bold"
                              Foreground="#FFEA00"
                              Margin="0,0,0,30"/>

                    <!-- 現在の状況 -->
                    <TextBlock Text="-- 現在の状況 --"
                              Foreground="White"
                              FontSize="16"
                              FontWeight="Bold"
                              Margin="0,0,0,20"/>

                    <!-- ラウンド情報 -->
                    <StackPanel Margin="0,0,0,30">
                        <TextBlock Text="ラウンド"
                                  Foreground="#CCCCCC"
                                  FontSize="14"/>
                        <TextBlock x:Name="RoundDisplay"
                                  Text="1 / 5"
                                  Foreground="LightBlue"
                                  FontSize="32"
                                  FontWeight="Bold"/>
                    </StackPanel>

                    <!-- 残り時間 -->
                    <StackPanel Margin="0,0,0,30">
                        <TextBlock Text="残り時間"
                                  Foreground="#CCCCCC"
                                  FontSize="14"/>
                        <TextBlock x:Name="TimeDisplay"
                                  Text="60 秒"
                                  Foreground="LightGreen"
                                  FontSize="32"
                                  FontWeight="Bold"/>
                    </StackPanel>

                    <!-- 操作方法 -->
                    <Border Background="#FF2D2D40"
                           CornerRadius="10"
                           Padding="15"
                           Margin="0,20,0,0">
                        <StackPanel>
                            <TextBlock Text="操作方法"
                                      Foreground="#FF00A8FF"
                                      FontSize="14"
                                      FontWeight="Bold"
                                      Margin="0,0,0,10"/>
                            <TextBlock Text="十字キー：ルート設定"
                                      Foreground="#CCCCCC"
                                      FontSize="12"/>
                            <TextBlock Text="Backspace：ひとつ戻る"
                                      Foreground="#CCCCCC"
                                      FontSize="12"/>

                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ========== 中央：マップ表示エリア ========== -->
            <Grid Grid.Row="0" Grid.Column="1">
                <Border Background="#1A237E"
                       CornerRadius="10"
                       Margin="-14,0,-16,0"
                       Padding="10">

                    <Canvas x:Name="MapCanvas"
                           Background="#FF1A1A2A"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                </Border>


            </Grid>

            <Border Grid.Row="0" Grid.Column="1"
                   Background="#1A237E"
                   BorderBrush="#1A237E"
                   BorderThickness="2,0,0,0" Grid.ColumnSpan="2" HorizontalAlignment="Right" Width="235">

                <StackPanel Margin="20">
                    <!-- スコア表示 -->
                    <Border Background="#FF2D2D40"
                           CornerRadius="10"
                           Padding="20">
                        <StackPanel>
                            <TextBlock Text="スコア"
                                      Foreground="#CCCCCC"
                                      FontSize="16"
                                      Margin="0,0,0,10"/>

                            <TextBlock x:Name="ScoreDisplay"
                                      Text="--"
                                      Foreground="Gold"
                                      FontSize="48"
                                      FontWeight="Bold"
                                      HorizontalAlignment="Center"/>


                        </StackPanel>
                    </Border>

                    <!-- ゲーム説明 -->
                    <Border Background="#FF2D2D40"
                           CornerRadius="10"
                           Padding="15"
                           Margin="0,30,0,0">
                        <TextBlock Text="水が拡散する前にゴールを目指せ！最短ルートで素早くゴールしよう。"
                                  Foreground="#CCCCCC"
                                  FontSize="12"
                                  TextWrapping="Wrap"/>
                    </Border>

                    <!-- 右下に終了ボタン -->
                    <Button Content="終了"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Bottom"
                           Width="80"
                           Height="40"
                           Background="Transparent"
                           Foreground="#CCCCCC"
                           BorderBrush="#FF007ACC"
                           BorderThickness="1"
                           Margin="0,30,0,0"
                           Click="ExitButton_Click">
                        <Button.Resources>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                        <Button.Style>
                            <Style TargetType="{x:Type Button}">
                                <Setter Property="Opacity" Value="0.8"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="1"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Background" Value="#4400A8FF"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>

            <!-- ========== 下部：シミュレーション開始ボタン ========== -->
            <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                   Background="#1A237E"
                   BorderBrush="#1A237E"
                   BorderThickness="0,2,0,0"
                   Padding="20">

                <Grid>
                    <!-- ボタンを中央に配置 -->
                    <Button x:Name="StartButton"
                           Content="シミュレーション開始"
                           Height="80"
                           Width="600"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Background="#B8DC70"
                           Foreground="White"
                           FontSize="24"
                           FontWeight="Bold"
                           BorderThickness="0"
                           Cursor="Hand"
                           Click="StartSimulationButton_Click">
                        <Button.Resources>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="CornerRadius" Value="15"/>
                            </Style>
                        </Button.Resources>
                        <Button.Style>
                            <Style TargetType="{x:Type Button}">
                                <Setter Property="Opacity" Value="0.9"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="1"/>
                                        <Setter Property="Background" Value="#FF0099FF"/>
                                        <Setter Property="RenderTransform">
                                            <Setter.Value>
                                                <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>