<Window x:Class="HazardGuessr.HomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HazardGuessr"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize">

	<Grid>
		<!-- MainWindowと同じ背景グラデーション -->
		<Grid.Background>
			<LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
				<GradientStop Color="Black"/>
				<GradientStop Color="#FF002158" Offset="1"/>
				<GradientStop Color="#FF000073"/>
				<GradientStop Color="#FF001A6B" Offset="0.9"/>
			</LinearGradientBrush>
		</Grid.Background>

		<!-- メインコンテンツ -->
		<Grid>
			<!-- ヘッダー：タイトルのみ -->
			<TextBlock Text="Hazard Guessr"
                      FontSize="48"
                      FontWeight="Bold"
                      Foreground="#FF00A8FF"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Top"
                      Margin="0,50,0,0"/>

			<!-- 中央：メインメニュー -->
			<Grid HorizontalAlignment="Center" VerticalAlignment="Center">
				<StackPanel>
					<!-- キャッチフレーズ -->
					<TextBlock Text="How do you guys escape?"
                              FontSize="28"
                              Foreground="White"
                              HorizontalAlignment="Center"
                              Margin="0,0,0,50"/>

					<!-- ゲーム開始ボタン -->
					<Button x:Name="StartGameButton"
                           Content="START"
                           Width="400"
                           Height="100"
                           Background="#FF007ACC"
                           Foreground="White"
                           FontSize="36"
                           FontWeight="Bold"
                           BorderThickness="0"
                           Cursor="Hand"
                           Margin="0,0,0,30"
                           Click="StartGameButton_Click">
						<Button.Resources>
							<Style TargetType="Border">
								<Setter Property="CornerRadius" Value="15"/>
							</Style>
						</Button.Resources>
						<Button.Style>
							<Style TargetType="Button">
								<Setter Property="Opacity" Value="0.9"/>
								<Style.Triggers>
									<Trigger Property="IsMouseOver" Value="True">
										<Setter Property="Opacity" Value="1"/>
										<Setter Property="Background" Value="#FF0099FF"/>
										<Setter Property="RenderTransform">
											<Setter.Value>
												<ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
											</Setter.Value>
										</Setter>
									</Trigger>
								</Style.Triggers>
							</Style>
						</Button.Style>
					</Button>

					<!-- サブメニューボタン -->
					<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
						<!-- ランキング表示ボタン -->
						<Button x:Name="RankingButton"
                               Content="ランキング表示"
                               Width="180"
                               Height="60"
                               Background="#FF2D2D40"
                               Foreground="White"
                               FontSize="18"
                               BorderBrush="#FF007ACC"
                               BorderThickness="2"
                               Margin="0,0,20,0"
                               Cursor="Hand"
                               Click="RankingButton_Click">
							<Button.Resources>
								<Style TargetType="Border">
									<Setter Property="CornerRadius" Value="10"/>
								</Style>
							</Button.Resources>
							<Button.Style>
								<Style TargetType="Button">
									<Setter Property="Opacity" Value="0.9"/>
									<Style.Triggers>
										<Trigger Property="IsMouseOver" Value="True">
											<Setter Property="Opacity" Value="1"/>
											<Setter Property="Background" Value="#FF3D3D50"/>
										</Trigger>
									</Style.Triggers>
								</Style>
							</Button.Style>
						</Button>

						<!-- ルール説明表示ボタン -->
						<Button x:Name="RulesButton"
                               Content="ルール説明"
                               Width="180"
                               Height="60"
                               Background="#FF2D2D40"
                               Foreground="White"
                               FontSize="18"
                               BorderBrush="#FF007ACC"
                               BorderThickness="2"
                               Cursor="Hand"
                               Click="RulesButton_Click">
							<Button.Resources>
								<Style TargetType="Border">
									<Setter Property="CornerRadius" Value="10"/>
								</Style>
							</Button.Resources>
							<Button.Style>
								<Style TargetType="Button">
									<Setter Property="Opacity" Value="0.9"/>
									<Style.Triggers>
										<Trigger Property="IsMouseOver" Value="True">
											<Setter Property="Opacity" Value="1"/>
											<Setter Property="Background" Value="#FF3D3D50"/>
										</Trigger>
									</Style.Triggers>
								</Style>
							</Button.Style>
						</Button>
					</StackPanel>
				</StackPanel>
			</Grid>

			<!-- 右上：終了ボタン -->
			<Button Content="終了"
                   Width="55"
                   Height="40"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Top"
                   Margin="0,20,20,0"
                   Background="Transparent"
                   Foreground="#CCCCCC"
                   FontSize="24"
                   FontWeight="Bold"
                   BorderThickness="0"
                   Click="CloseButton_Click">
				<Button.Style>
					<Style TargetType="Button">
						<Setter Property="Opacity" Value="0.7"/>
						<Style.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter Property="Opacity" Value="1"/>
								<Setter Property="Foreground" Value="White"/>
								<Setter Property="Background" Value="#44FF0000"/>
							</Trigger>
						</Style.Triggers>
					</Style>
				</Button.Style>
			</Button>

			<!-- 右下：Logoutボタン -->
			<Button x:Name="LogoutButton"
                   Content="Logout"
                   Width="100"
                   Height="40"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Bottom"
                   Margin="0,0,20,20"
                   Background="Transparent"
                   Foreground="#CCCCCC"
                   BorderBrush="#FF007ACC"
                   BorderThickness="1"
                   FontSize="14"
                   Cursor="Hand"
                   Click="LogoutButton_Click">
				<Button.Resources>
					<Style TargetType="Border">
						<Setter Property="CornerRadius" Value="5"/>
					</Style>
				</Button.Resources>
				<Button.Style>
					<Style TargetType="Button">
						<Setter Property="Opacity" Value="0.8"/>
						<Style.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter Property="Opacity" Value="1"/>
								<Setter Property="Foreground" Value="White"/>
								<Setter Property="Background" Value="#4400A8FF"/>
							</Trigger>
						</Style.Triggers>
					</Style>
				</Button.Style>
			</Button>
		</Grid>
	</Grid>
</Window>