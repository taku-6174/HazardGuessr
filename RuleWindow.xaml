<Window x:Class="HazardGuessr.RuleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        Title="HazardGuessr - ルール説明">

    <Grid>
        <!-- 背景グラデーション（他の画面と同じ） -->
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="#1A237E"/>
                
            </LinearGradientBrush>
        </Grid.Background>

        <!-- メインコンテンツ -->
        <Grid Margin="40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- タイトル -->
            <TextBlock Text="ルール説明"
                      FontSize="48"
                      FontWeight="Bold"
                      Foreground="#FF00A8FF"
                      HorizontalAlignment="Center"
                      Grid.Row="0"
                      Margin="0,0,0,30"/>

            <!-- 説明内容（スクロール可能） -->
            <ScrollViewer Grid.Row="1"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled">

                <StackPanel Margin="0,0,20,0">

                    <!-- ゲーム概要 -->
                    <Border Background="#FF1A1A2E"
                           CornerRadius="10"
                           BorderBrush="#FF007ACC"
                           BorderThickness="2"
                           Padding="20"
                           Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="ゲーム概要"
                                      FontSize="24"
                                      FontWeight="Bold"
                                      Foreground="#FF00A8FF"
                                      Margin="0,0,0,15"/>

                            <TextBlock Text="「HazardGuessr」は、災害発生時における避難判断力の育成を目的とした、マップ型の災害避難シミュレーションである"
                                      FontSize="18"
                                      Foreground="White"
                                      TextWrapping="Wrap"
                                      LineHeight="30"/>
                        </StackPanel>
                    </Border>

                    <!-- 目的 -->
                    <Border Background="#FF2D2D40"
                           CornerRadius="10"
                           Padding="20"
                           Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text=" 目的"
                                      FontSize="22"
                                      FontWeight="Bold"
                                      Foreground="LightGreen"
                                      Margin="0,0,0,10"/>

                            <TextBlock FontSize="16"
                               Foreground="#CCCCCC"
                               TextWrapping="Wrap"
                               LineHeight="26"
                               Height="Auto"> 近年、大雨による川の氾濫や地震などの自然災害が多発し、多くの人々が避難を余儀なくされています。<LineBreak/>
                                その際、安全かつ最短の避難ルートを素早く判断し、迅速に行動する力が命を守るカギとなります。<LineBreak/>
                                しかし、日常でハザードマップを見る機会は限られており、災害時の具体的な判断力を身につけることは難しいのが現状です。<LineBreak/>
                                そこで本作では、ゲームを通じて誰でも楽しくハザードマップや避難行動を学べる環境を提供し、災害時に命を守る力を育むことを目的としています。
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- 操作方法 -->
                    <Border Background="#FF2D2D40"
                           CornerRadius="10"
                           Padding="20"
                           Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="🎮 操作方法"
                                      FontSize="22"
                                      FontWeight="Bold"
                                      Foreground="LightBlue"
                                      Margin="0,0,0,10"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- 十字キー -->
                                <TextBlock Text="十字キー"
                                          FontSize="16"
                                          FontWeight="Bold"
                                          Foreground="White"
                                          Grid.Row="0" Grid.Column="0"
                                          Margin="0,0,15,10"/>
                                <TextBlock Text="ルートを設定します。一度通ったマスには戻れません。"
                                          FontSize="16"
                                          Foreground="#CCCCCC"
                                          Grid.Row="0" Grid.Column="1"
                                          TextWrapping="Wrap"
                                          Margin="0,0,0,10"/>

                                <!-- Backspace -->
                                <TextBlock Text="Backspace"
                                          FontSize="16"
                                          FontWeight="Bold"
                                          Foreground="White"
                                          Grid.Row="1" Grid.Column="0"
                                          Margin="0,0,15,10"/>
                                <TextBlock Text="ルートをひとつ戻ります（Undo）。"
                                          FontSize="16"
                                          Foreground="#CCCCCC"
                                          Grid.Row="1" Grid.Column="1"
                                          TextWrapping="Wrap"
                                          Margin="0,0,0,10"/>

                                <!-- ボタン -->
                                <TextBlock Text="ボタン操作"
                                          FontSize="16"
                                          FontWeight="Bold"
                                          Foreground="White"
                                          Grid.Row="2" Grid.Column="0"
                                          Margin="0,0,15,0"/>
                                <TextBlock Text="「シミュレーション開始」でルートを確定、「次のマップへ」で続行します。"
                                          FontSize="16"
                                          Foreground="#CCCCCC"
                                          Grid.Row="2" Grid.Column="1"
                                          TextWrapping="Wrap"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- 地形説明 -->
                    <Border Background="#FF2D2D40"
                           CornerRadius="10"
                           Padding="20"
                           Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="🗺️ 地形の種類"
                                      FontSize="22"
                                      FontWeight="Bold"
                                      Foreground="#FFD700"
                                      Margin="0,0,0,10"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- 道 -->
                                <Border Width="20" Height="20"
                                       Background="LightGray"
                                       Grid.Row="0" Grid.Column="0"
                                       Margin="0,0,15,10"/>
                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,10">
                                    <TextBlock Text="道（白/薄灰）"
                                              FontSize="16"
                                              FontWeight="Bold"
                                              Foreground="White"/>
                                    <TextBlock Text="移動可能なエリアです。"
                                              FontSize="14"
                                              Foreground="#CCCCCC"/>
                                </StackPanel>

                                <!-- 川 -->
                                <Border Width="20" Height="20"
                                       Background="Blue"
                                       Grid.Row="1" Grid.Column="0"
                                       Margin="0,0,15,10"/>
                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,10">
                                    <TextBlock Text="川（青）"
                                              FontSize="16"
                                              FontWeight="Bold"
                                              Foreground="White"/>
                                    <TextBlock Text="水の氾濫元です。時間とともに周囲に広がります。"
                                              FontSize="14"
                                              Foreground="#CCCCCC"/>
                                </StackPanel>

                                <!-- 山 -->
                                <Border Width="20" Height="20"
                                       Background="DarkGreen"
                                       Grid.Row="2" Grid.Column="0"
                                       Margin="0,0,15,10"/>
                                <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,10">
                                    <TextBlock Text="山（濃緑）"
                                              FontSize="16"
                                              FontWeight="Bold"
                                              Foreground="White"/>
                                    <TextBlock Text="移動不可能な障害物です。"
                                              FontSize="14"
                                              Foreground="#CCCCCC"/>
                                </StackPanel>

                                <!-- 建物 -->
                                <Border Width="20" Height="20"
                                       Background="LightGreen"
                                       Grid.Row="3" Grid.Column="0"
                                       Margin="0,0,15,0"/>
                                <StackPanel Grid.Row="3" Grid.Column="1">
                                    <TextBlock Text="建物（薄緑）"
                                              FontSize="16"
                                              FontWeight="Bold"
                                              Foreground="White"/>
                                    <TextBlock Text="移動不可能な障害物です。"
                                              FontSize="14"
                                              Foreground="#CCCCCC"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    

                    <!-- ゲームの流れ -->
                    <Border Background="#FF1A1A2E"
                           CornerRadius="10"
                           BorderBrush="#FF007ACC"
                           BorderThickness="2"
                           Padding="20">
                        <StackPanel>
                            <TextBlock Text="🔄 ゲームの流れ"
                                      FontSize="24"
                                      FontWeight="Bold"
                                      Foreground="#FF00A8FF"
                                      Margin="0,0,0,15"/>

                            <ListBox BorderThickness="0" Background="Transparent">
                                <ListBoxItem>
                                    <TextBlock Text="1. スタート地点からゴールまでのルートを設定"
                                              FontSize="16"
                                              Foreground="White"/>
                                </ListBoxItem>
                                <ListBoxItem>
                                    <TextBlock Text="2. 「シミュレーション開始」ボタンを押す"
                                              FontSize="16"
                                              Foreground="White"/>
                                </ListBoxItem>
                                <ListBoxItem>
                                    <TextBlock Text="3. キャラクターがルートを移動するのを見守る"
                                              FontSize="16"
                                              Foreground="White"/>
                                </ListBoxItem>
                                <ListBoxItem>
                                    <TextBlock Text="4. 水が拡散し、危険なエリアが広がる"
                                              FontSize="16"
                                              Foreground="White"/>
                                </ListBoxItem>
                                <ListBoxItem>
                                    <TextBlock Text="5. ゴール到達かゲームオーバーでラウンド終了"
                                              FontSize="16"
                                              Foreground="White"/>
                                </ListBoxItem>
                                <ListBoxItem>
                                    <TextBlock Text="6. 5ラウンド終了後、最終スコアを確認"
                                              FontSize="16"
                                              Foreground="White"/>
                                </ListBoxItem>
                            </ListBox>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- 戻るボタン -->
            <Button x:Name="BackButton"
                   Content="ホームに戻る"
                   Width="200"
                   Height="50"
                   Background="#FF007ACC"
                   Foreground="White"
                   FontSize="18"
                   FontWeight="Bold"
                   BorderThickness="0"
                   HorizontalAlignment="Center"
                   Grid.Row="2"
                   Margin="0,30,0,0"
                   Cursor="Hand"
                   Click="BackButton_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="10"/>
                    </Style>
                </Button.Resources>
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Opacity" Value="0.9"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="1"/>
                                <Setter Property="Background" Value="#FF0099FF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>

        
    </Grid>
</Window>