<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:av="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="av" x:Class="HazardGuessr.LoginWindow"
        Title="HazardGuessr - ログイン"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        Loaded="Window_Loaded" av:DesignHeight="706.751" av:DesignWidth="1012.658">

    <Grid>
        <!-- MainWindowと同じ背景グラデーション -->
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="#1A237E"/>
                
            </LinearGradientBrush>
        </Grid.Background>

        <!-- 中央ログインボックス -->
        <Border Background="#1E293B"
                CornerRadius="15"
                Width="500"
                Height="500"
                BorderBrush="#FF007ACC"
                BorderThickness="3"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <Grid Margin="30">
                <!-- タイトル -->
                <TextBlock Text="HazardGuessr"
                          FontSize="36"
                          FontWeight="Bold"
                          Foreground="#FFEA00"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Top"
                          Margin="0,10,0,0"/>

                <!-- サブタイトル -->
                <TextBlock x:Name="SubtitleText"
                          Text="ログイン"
                          FontSize="24"
                          Foreground="White"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Top"
                          Margin="0,60,0,0"/>

                <!-- 入力エリア -->
                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Width="350"
                            Margin="0,50,0,0">

                    <!-- ユーザー名入力 -->
                    <TextBlock Text="ユーザー名"
                              Foreground="#CCCCCC"
                              FontSize="16"
                              Margin="0,0,0,5"/>

                    <!-- シンプルなTextBox（カスタムテンプレートなし） -->
                    <TextBox x:Name="PlayerNameTextBox"
                            Height="50"
                            Background="#FF2D2D40"
                            Foreground="White"
                            BorderBrush="#FF007ACC"
                            BorderThickness="2"
                            FontSize="16"
                            CaretBrush="White"
                            Padding="10"
                            Margin="0,0,0,15"
                            TextChanged="PlayerNameTextBox_TextChanged" Cursor=""/>

                    <!-- パスワード入力 -->
                    <Grid x:Name="PasswordGrid" Margin="0,0,0,15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="PasswordLabel"
                                  Text="パスワード"
                                  Foreground="#CCCCCC"
                                  FontSize="16"
                                  Margin="0,0,0,5"/>

                        <!-- シンプルなTextBox（パスワード用） -->
                        <TextBox x:Name="PasswordTextBox"
                                Grid.Row="1"
                                Height="50"
                                Background="#FF2D2D40"
                                Foreground="White"
                                BorderBrush="#FF007ACC"
                                BorderThickness="2"
                                FontSize="16"
                                CaretBrush="White"
                                Padding="10"
                                Margin="0,0,0,0"
                                TextChanged="PasswordTextBox_TextChanged"/>
                    </Grid>

                    <!-- モード表示 -->
                    <TextBlock x:Name="ModeText"
                              Text="ログインモード"
                              FontSize="14"
                              Foreground="#4CAF50"
                              HorizontalAlignment="Center"
                              Margin="0,0,0,10"
                              FontWeight="Bold"/>

                    <!-- ゲストオプション -->
                    <CheckBox x:Name="GuestCheckBox"
                             Content="ゲストとしてプレイ"
                             Foreground="#CCCCCC"
                             FontSize="14"
                             Margin="0,0,0,20"
                             Checked="GuestCheckBox_Checked"
                             Unchecked="GuestCheckBox_Unchecked">
                        <!-- シンプルなCheckBoxスタイル -->
                        <CheckBox.Style>
                            <Style TargetType="{x:Type CheckBox}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type CheckBox}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border x:Name="border" 
                                                        Width="18" 
                                                        Height="18" 
                                                        Background="#FF2D2D40" 
                                                        BorderBrush="#FF007ACC" 
                                                        BorderThickness="2" 
                                                        CornerRadius="3"/>
                                                <ContentPresenter Grid.Column="1" 
                                                                  Margin="10,0,0,0" 
                                                                  VerticalAlignment="Center"/>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#FF007ACC"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </CheckBox.Style>
                    </CheckBox>

                    <!-- スタートボタン -->
                    <Button x:Name="StartButton"
                           Content="ログイン"
                           Height="50"
                           Background="#B8DC70"
                           Foreground="White"
                           FontSize="18"
                           FontWeight="Bold"
                           BorderThickness="0"
                           Cursor="Hand"
                           Click="StartButton_Click">
                        <!-- シンプルなButtonスタイル -->
                        <Button.Style>
                            <Style TargetType="{x:Type Button}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type Button}">
                                            <Border x:Name="border"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Opacity" Value="0.9"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="1"/>
                                        <Setter Property="Background" Value="#FF0099FF"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Opacity" Value="0.5"/>
                                        <Setter Property="Background" Value="#666666"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- エラーメッセージ -->
                    <TextBlock x:Name="ErrorText"
                              Foreground="#FFFF6B6B"
                              FontSize="14"
                              HorizontalAlignment="Center"
                              Margin="0,0,0,0"
                              TextWrapping="Wrap"
                              Visibility="Collapsed"/>

                    <!-- 情報メッセージ -->
                    <TextBlock x:Name="InfoText"
                              Foreground="#4CAF50"
                              FontSize="12"
                              HorizontalAlignment="Center"
                              Margin="0,0,0,0"
                              TextWrapping="Wrap"
                              Visibility="Collapsed"/>
                </StackPanel>

            </Grid>
        </Border>

        <!-- 右上に閉じるボタン -->
        <Button Content="×"
               Width="40"
               Height="40"
               HorizontalAlignment="Right"
               VerticalAlignment="Top"
               Margin="0,20,20,0"
               Background="Transparent"
               Foreground="#CCCCCC"
               FontSize="24"
               FontWeight="Bold"
               BorderThickness="0"
               Click="CloseButton_Click">
            <Button.Style>
                <Style TargetType="{x:Type Button}">
                    <Setter Property="Opacity" Value="0.7"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Opacity" Value="1"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Background" Value="#44FF0000"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>
    </Grid>
</Window>